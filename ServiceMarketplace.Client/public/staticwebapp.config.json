{
  "routes": [
    {
      "route": "/favicon.ico",
      "redirect": "/favicon.svg",
      "statusCode": 301
    },
    {
      "route": "/favicon.svg",
      "headers": {
        "Content-Type": "image/svg+xml; charset=utf-8",
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/site.webmanifest",
      "headers": {
        "Content-Type": "application/manifest+json; charset=utf-8",
        "Cache-Control": "public, max-age=86400"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/favicon.svg",
      "/favicon.ico",
      "/icons.svg",
      "/site.webmanifest"
    ]
  }
}
